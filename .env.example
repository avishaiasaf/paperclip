# ==============================================================================
# Paperclip Configuration
# ==============================================================================
# Copy this file to .env and fill in the required values.
# Lines marked [REQUIRED] must be set for production deployment.
# ==============================================================================

# --- Networking (Tailscale) ---------------------------------------------------

# [REQUIRED] Your server's Tailscale IP (run: tailscale ip -4)
TAILSCALE_IP=

# [REQUIRED] The URL Paperclip is reachable at.
# Use your Tailscale IP:  http://100.x.x.x
# Or MagicDNS hostname:   http://your-server.your-tailnet.ts.net
PAPERCLIP_PUBLIC_URL=

# Domain for Caddy reverse proxy.
# Set to your Tailscale MagicDNS hostname, or leave empty for "localhost".
# Examples: your-server.your-tailnet.ts.net
PAPERCLIP_DOMAIN=

# Comma-separated hostnames the server accepts (Host header validation).
# Auto-derived from PAPERCLIP_PUBLIC_URL. Set this if you access via multiple
# hostnames (e.g. both the Tailscale IP and MagicDNS name).
# PAPERCLIP_ALLOWED_HOSTNAMES=100.x.x.x,your-server.your-tailnet.ts.net

# --- Authentication ----------------------------------------------------------

# [REQUIRED] Secret for signing auth sessions. Minimum 32 characters.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Deployment mode: "authenticated" (requires login) or "local_trusted" (no auth)
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# Deployment exposure: "private" (Tailscale/VPN) or "public" (internet-facing)
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Disable new user sign-up (set to true after creating your account)
PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# Comma-separated trusted origins for auth cookies.
# Auto-derived from PAPERCLIP_PUBLIC_URL. Only set if accessing from additional origins.
# BETTER_AUTH_TRUSTED_ORIGINS=

# --- Data Persistence ---------------------------------------------------------

# Host directory for Paperclip data (database, config, backups, attachments).
# Mounted as /paperclip inside the container.
PAPERCLIP_DATA_DIR=./data/paperclip

# --- LLM Provider Keys -------------------------------------------------------

# At least one is needed for agents to function.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database Backups ---------------------------------------------------------

PAPERCLIP_DB_BACKUP_ENABLED=true
PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30

# --- Agent Scheduling ---------------------------------------------------------

# Enable/disable the heartbeat scheduler (agents running on schedules)
HEARTBEAT_SCHEDULER_ENABLED=true

# --- Local Development (not needed for production) ----------------------------

# DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
# PORT=3100
# SERVE_UI=false
